{
  "name": "quickpoll",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install-all": "npm install --workspaces",
    "dev": "concurrently \"npm --workspace backend run dev\" \"npm --workspace frontend run dev\""
  },
  "devDependencies": {
    "concurrently": "^8.0.1"
  }
}
